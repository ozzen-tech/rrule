{
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./dist/esm",
    "declaration": true,
    "declarationMap": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "target": "es5",
    "importHelpers": true,
    "esModuleInterop": true,
    "rootDirs": ["./src/"],
    "inlineSources": true
  },
  "include": ["./src/**/*"],
  "exclude": ["node_modules", "./test/**/*"]
}
